# PostgreSQL
POSTGRES_USER=bsn_site_user
POSTGRES_PASSWORD=bsn_site_password
POSTGRES_DB=bsn_site_db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cloudflare R2
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your-bucket.r2.dev
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# App
BACKEND_PORT=3001
FRONTEND_PORT=8080
JWT_SECRET=bsn-site-jwt-secret-change-in-production

# SMTP (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bsnsolution.com.br