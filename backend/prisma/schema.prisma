generator client {
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Usuários admin
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  blogPosts  BlogPost[]
  messageReplies MessageReply[]

  @@map("users")
}

enum Role {
  ADMIN
  EDITOR
}

// Configurações do site
model SiteSettings {
  id              String  @id @default(uuid())
  siteName        String  @default("BSN Solution")
  siteDescription String?
  logoUrl         String?
  faviconUrl      String?
  email           String?
  phone           String?
  address         String?
  
  // Redes sociais
  facebookUrl     String?
  instagramUrl    String?
  linkedinUrl     String?
  twitterUrl      String?
  youtubeUrl      String?
  
  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  
  // Configurações gerais
  maintenanceMode Boolean @default(false)
  allowContactForm Boolean @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("site_settings")
}

// Seções da página home
model HomeSection {
  id          String      @id @default(uuid())
  type        SectionType
  title       String?
  subtitle    String?
  content     String?
  imageUrl    String?
  ctaText     String?
  ctaUrl      String?
  isVisible   Boolean     @default(true)
  order       Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("home_sections")
}

enum SectionType {
  HERO
  ABOUT
  SERVICES_PREVIEW
  SOLUTIONS_PREVIEW
  TESTIMONIALS_PREVIEW
  CALL_TO_ACTION
  STATS
}

// Serviços
model Service {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?  // ex: "sob medida" — segunda linha do h2 da página de serviço
  description String   // lede/resumo
  content     String?
  imageUrl    String?
  iconName    String?
  // Anchor para a URL da página /servicos (ex: "sob-medida", "squads")
  anchor      String?
  // Número exibido (ex: "SVC · 01")
  numLabel    String?
  // Classe de cor da shard: v (violet), c (cyan), m (magenta), a (amber), e (emerald)
  shardColor  String?  @default("v")
  // Label da CTA que aparece no card de serviço
  ctaLabel    String?  @default("Falar sobre um projeto ↗")
  // Lista de 4 features (bullets 2x2) — array JSON de {title, description}
  features    Json?
  // Tile class (t1..t7) + pills para o mosaico da home
  tileClass   String?
  homePill    String?  // ex: "Plug & play", "SLA 24/7"
  homePillTags String[] // para o tile 7 (Dev, DevOps, QA, Data, Produto)
  isActive    Boolean  @default(true)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

// Soluções/Portfólio
model Solution {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String
  content     String?
  imageUrl    String?
  technologies String[] // Array de tecnologias usadas
  projectUrl  String?
  githubUrl   String?
  // Tag (ex: COOPERATIVISMO, CONSÓRCIOS) exibida acima do título
  tag         String?
  // Classe de cor (a..f)
  colorClass  String?  @default("a")
  // Bullets exibidos como lista com square colorido no card
  bullets     String[]
  // Label da CTA
  ctaLabel    String?  @default("Ver demo →")
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("solutions")
}

// Depoimentos
model Testimonial {
  id         String   @id @default(uuid())
  clientName String
  clientRole String?
  company    String?
  content    String
  rating     Int      @default(5)
  avatarUrl  String?
  isActive   Boolean  @default(true)
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("testimonials")
}

// Blog
model BlogPost {
  id          String       @id @default(uuid())
  title       String
  slug        String       @unique
  excerpt     String?
  content     String
  coverImage  String?
  tags        String[]
  isPublished Boolean      @default(false)
  isFeatured  Boolean      @default(false)
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  // Relacionamentos
  authorId    String
  author      User         @relation(fields: [authorId], references: [id])

  @@map("blog_posts")
}

// Equipe
model TeamMember {
  id          String   @id @default(uuid())
  name        String
  role        String
  bio         String?
  imageUrl    String?
  email       String?
  linkedinUrl String?
  twitterUrl  String?
  githubUrl   String?
  // Variante do avatar gradient quando não tem imagem: "default" (violet→magenta), "b" (cyan→emerald), "c" (amber→magenta)
  avatarVariant String? @default("default")
  isActive    Boolean  @default(true)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("team_members")
}

// Clientes (logos)
model Client {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String
  websiteUrl String?
  isActive  Boolean  @default(true)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

// Vagas
model Job {
  id          String   @id @default(uuid())
  title       String
  description String
  requirements String?  // ex: "TypeScript · Node · React"
  benefits    String?
  location    String?  // ex: "REMOTO", "SP · HÍBRIDO"
  type        JobType  @default(FULL_TIME)
  salary      String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  applications JobApplication[]

  @@map("jobs")
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

// Candidaturas
model JobApplication {
  id       String   @id @default(uuid())
  name     String
  email    String
  phone    String?
  message  String?
  resumeUrl String?
  status   ApplicationStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  jobId    String
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_applications")
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

// Mensagens de contato
model ContactMessage {
  id        String      @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    MessageStatus @default(UNREAD)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relacionamentos
  replies   MessageReply[]

  @@map("contact_messages")
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

// Respostas às mensagens
model MessageReply {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  
  // Relacionamentos
  messageId String
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@map("message_replies")
}

// Uploads de imagem
model UploadedImage {
  id       String   @id @default(uuid())
  filename String
  originalName String?
  mimeType String
  size     Int
  url      String
  r2Key    String?
  createdAt DateTime @default(now())

  @@map("uploaded_images")
}

// Analytics simplificado
model AnalyticsEvent {
  id        String   @id @default(uuid())
  event     String
  page      String?
  userAgent String?
  ip        String?
  data      Json?
  createdAt DateTime @default(now())

  @@map("analytics_events")
}

// Card "ao vivo" exibido no hero direito da home
model HomeLiveCard {
  id         String   @id @default(uuid())
  label      String   @default("Ao vivo · operação 24/7")
  title      String   @default("Monitoramos 32 projetos em produção agora mesmo.")
  // Cada linha: {label, value, highlight: "up" | null}
  rows       Json
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("home_live_cards")
}

// Cartão lateral (pill) de depoimento no hero direito da home
model HomeBrandPill {
  id         String   @id @default(uuid())
  personName String   @default("Carolina Menezes")
  company    String?  @default("FinCo")
  quote      String   @default("\"Ritmo de entrega 3× superior ao esperado.\"")
  avatarUrl  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("home_brand_pills")
}

// Seção "Filosofia" (band) da home
model HomeBand {
  id         String   @id @default(uuid())
  eyebrow    String   @default("FILOSOFIA")
  // Usa HTML para permitir <em> e <br>
  title      String   @default("Software fácil de usar. <em>Difícil de ignorar.</em><br>Feito para durar tanto quanto sua empresa.")
  ctaLabel   String   @default("Conversar com um especialista ↗")
  ctaUrl     String   @default("/contato")
  mono       String   @default("Diagnóstico inicial gratuito · 45 min")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("home_bands")
}

// Items de stack no marquee da home
model StackItem {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(true)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stack_items")
}

// Cards "Sobre" da página /sobre (Missão/Visão/Forma/Evitamos)
model AboutCard {
  id          String   @id @default(uuid())
  tag         String   // ex: "MISSÃO", "VISÃO"
  title       String
  description String
  // Classe de cor/posição (c1, c2, c3, c4)
  colorClass  String   @default("c1")
  isActive    Boolean  @default(true)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("about_cards")
}

// Valores / Princípios (página Sobre)
model Value {
  id          String   @id @default(uuid())
  number      String   // "01", "02"...
  title       String
  description String
  isActive    Boolean  @default(true)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("values")
}

// KPIs exibidos na home
model HomeKPI {
  id        String   @id @default(uuid())
  label     String   // "EXPERIÊNCIA"
  value     String   // "12"
  suffix    String?  // "+", "/7", "dias"
  caption   String?  // "anos entregando..."
  isActive  Boolean  @default(true)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("home_kpis")
}

// Benefícios / Perks (página Carreiras)
model Perk {
  id          String   @id @default(uuid())
  title       String
  description String
  isActive    Boolean  @default(true)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("perks")
}

// Menu do footer
model FooterMenu {
  id        String      @id @default(uuid())
  title     String
  url       String?
  order     Int
  isActive  Boolean     @default(true)
  parentId  String?
  parent    FooterMenu? @relation("FooterMenuHierarchy", fields: [parentId], references: [id])
  children  FooterMenu[] @relation("FooterMenuHierarchy")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("footer_menus")
}